# Copy to .env and adjust. NEVER commit .env.

# Django
SECRET_KEY=change-me-generate-a-real-one
DEBUG=True

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/industry_rockstar?connect_timeout=5

# Host routing
# BASE_DOMAIN: the wildcard base for published sites ({subdomain}.BASE_DOMAIN).
# APP_HOST: the exact host of the control plane (editor/admin).
# Port is included in dev; production values look like:
#   BASE_DOMAIN=yourdomain.com
#   APP_HOST=app.yourdomain.com
BASE_DOMAIN=localhost:8000
APP_HOST=app.localhost:8000

# OpenAI — LLM annotation at import (architecture.md §7, Phase 3).
# Leave OPENAI_API_KEY empty to skip annotation entirely: imports still succeed,
# they just land with no editable fields (the manual path). Set it to turn on
# the skeleton -> structured-output -> materialize pass.
OPENAI_API_KEY=
# Full gpt-4o by default for label accuracy. Drop to gpt-4o-mini to cut cost, or
# set a newer/stronger model your account has — it just needs structured outputs.
OPENAI_MODEL=gpt-4o
# Blended cents per 1K tokens, used only to fill ImportJob.cost_cents. 0 = don't estimate.
OPENAI_COST_CENTS_PER_1K=0
